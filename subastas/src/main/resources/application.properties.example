spring.application.name=subastas

server.port=8080

# Copiá este archivo como application.properties y completá los valores reales.
# Nunca subas application.properties al repo.

spring.datasource.url=jdbc:postgresql://<host>:5432/postgres?ssl=true&sslfactory=org.postgresql.ssl.NonValidatingFactory
spring.datasource.username=<usuario_supabase>
spring.datasource.password=<contraseña_supabase>
spring.datasource.driver-class-name=org.postgresql.Driver

spring.jpa.database-platform=org.hibernate.dialect.PostgreSQLDialect
spring.jpa.hibernate.ddl-auto=none
spring.jpa.show-sql=true
spring.jpa.open-in-view=false
logging.level.org.springframework.security=DEBUG
