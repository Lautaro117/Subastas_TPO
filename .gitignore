# Secrets - nunca subir
# application.properties ya NO tiene secrets (usa variables de entorno, ver Render) y se
# sube a propósito. Los secrets reales viven en application-local.properties (solo local)
# y en las env vars del servicio en Render.
subastas/src/main/resources/application-local.properties
**/.env

# Build output
subastas/target/

# Maven wrapper jar
subastas/.mvn/wrapper/maven-wrapper.jar

# IDEs
.idea/
*.iws
*.iml
*.ipr
.vscode/
.classpath
.project
.settings/
.springBeans

# macOS
.DS_Store
